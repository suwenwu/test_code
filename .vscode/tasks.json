{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: clang build active file (C++23)",
            "command": "/usr/bin/clang++", // macOS 自带 clang++ 路径
            "args": [
                "-g", // 保留调试信息（断点必需）
                "-std=c++23", // 核心：指定 C++23 标准（也可用 c++2b，效果一致）
                "-O0", // 禁用编译器优化（调试时避免断点异常，可选但推荐）
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "编译 C++23 代码，带调试信息"
        }
    ]
}